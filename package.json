{
  "name": "shortify-hub",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=24.0.0"
  },
  "scripts": {
    "dev": "node scripts/dev.mjs",
    "start": "node backend/server.mjs",
    "start:frontend": "node scripts/frontend-server.mjs",
    "start:worker": "node worker/worker.mjs",
    "check": "node scripts/check.mjs",
    "test": "node --test --test-reporter=spec",
    "test:e2e": "node tests/e2e.mjs",
    "verify": "npm run check && npm test"
  },
  "devDependencies": {
    "playwright": "1.61.1"
  }
}
